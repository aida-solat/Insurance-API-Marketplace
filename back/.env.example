# Copy to `.env` and fill in the values you want. Any unset variable falls
# back to a safe default; in particular, if no LLM key is provided the
# platform runs in heuristic mode (fully functional, no external calls).

# ---- Persistence ------------------------------------------------------------
DATABASE_URL=sqlite:///./data.db

# ---- CORS -------------------------------------------------------------------
CORS_ORIGINS=*

# ---- LLM provider selection -------------------------------------------------
# auto | openai | anthropic | ollama | heuristic
LLM_PROVIDER=auto

# ---- OpenAI -----------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# ---- Anthropic --------------------------------------------------------------
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-haiku-latest

# ---- Ollama (local) ---------------------------------------------------------
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2
